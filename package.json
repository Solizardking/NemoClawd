{
  "name": "@mawdbotsonsolana/nemoclawd",
  "version": "0.5.0",
  "description": "nemoClawd — xAI Grok powered Solana agentic trading engine with $CLAWD token, 31 MCP tools, multi-agent research, and Telegram trading bot.",
  "license": "Apache-2.0",
  "keywords": [
    "solana",
    "pump-fun",
    "trading-bot",
    "telegram-bot",
    "solana-developer-tools",
    "solana-agent",
    "pumpfun",
    "agentic-wallet",
    "privy",
    "openclaw",
    "openshell",
    "nvidia",
    "ai-agent",
    "defi",
    "autonomous-agent",
    "ollama",
    "deepsolana",
    "xai",
    "grok",
    "mcp",
    "solana-clawd",
    "memecoin",
    "solana-trading"
  ],
  "bin": {
    "nemoclawd": "bin/nemoclawd.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "build:plugin": "npm --prefix nemoclawd run build",
    "build:mcp": "npm --prefix nemoclawd-mcp run build",
    "build": "npm run build:plugin && npm run build:mcp",
    "public:audit": "bash scripts/public-release-audit.sh",
    "pack:check": "npm pack --dry-run --cache /tmp/nemoclawd-npm-cache",
    "openrouter:smoke": "node scripts/openrouter-smoke.mjs",
    "release:check": "npm run build && npm test && npm run public:audit && npm run pack:check",
    "publish:public": "npm publish --access public",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.13.7",
    "openclaw": "2026.6.9"
  },
  "files": [
    "bin/",
    "SKILL.md",
    "nemoclawd/dist/",
    "nemoclawd/openclaw.plugin.json",
    "nemoclawd/package.json",
    "nemoclawd-mcp/dist/",
    "nemoclawd-mcp/src/",
    "nemoclawd-mcp/package.json",
    "nemoclawd-mcp/README.md",
    "nemoclawd-mcp/tsconfig.json",
    "nemoclawd-blueprint/",
    "Pump-Fun/src/",
    "Pump-Fun/agent-app/",
    "Pump-Fun/agent-tasks/",
    "Pump-Fun/docs/",
    "Pump-Fun/packages/defi-agents/",
    "Pump-Fun/pumpkit/",
    "Pump-Fun/pumpkit/agent-prompts/",
    "Pump-Fun/pumpkit/tutorials/",
    "Pump-Fun/telegram-bot/",
    "Pump-Fun/swarm-bot/",
    "Pump-Fun/websocket-server/",
    "Pump-Fun/tools/",
    "Pump-Fun/x402/",
    "pump-fun-skills-main/tokenized-agents/",
    "scripts/brev-setup.sh",
    "scripts/fix-coredns.sh",
    "scripts/install-vulcan.sh",
    "scripts/install-openshell.sh",
    "scripts/install.sh",
    "scripts/nemoclawd-payment-app.sh",
    "scripts/nemoclawd-phoenix-perps.sh",
    "scripts/nemoclawd-solana-agent.sh",
    "scripts/nemoclawd-solana-bridge.sh",
    "scripts/nemoclawd-solana-stack.sh",
    "scripts/nemoclawd-start.sh",
    "scripts/nemoclawd-swarm-bot.sh",
    "scripts/nemoclawd-telegram-bot.sh",
    "scripts/nemoclawd-websocket-server.sh",
    "scripts/openrouter-smoke.mjs",
    "scripts/pre-commit-secrets.sh",
    "scripts/public-release-audit.sh",
    "scripts/setup-spark.sh",
    "scripts/setup.sh",
    "scripts/start-services.sh",
    "scripts/test-inference-local.sh",
    "scripts/test-inference.sh",
    "scripts/walkthrough.sh",
    "scripts/write-auth-profile.py",
    "Dockerfile",
    ".dockerignore"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x402agent/NemoClawd.git"
  },
  "homepage": "https://nemo.nanosolana.com",
